PORT=4000
ETH_RPC_URL=http://127.0.0.1:8545

# Admin private key (must match deployer of Voting contract)
ADMIN_PRIVATE_KEY=0xYOUR_ADMIN_PRIVATE_KEY_HERE

# Voter private key (second account from Hardhat node or Ganache)
VOTER_PRIVATE_KEY=0xYOUR_VOTER_PRIVATE_KEY_HERE

# PostgreSQL configuration
PGHOST=localhost
PGPORT=5432
PGUSER=voting
PGPASSWORD=yourpassword
PGDATABASE=votingdb

# JWT secret for signing access tokens
JWT_SECRET=supersecretjwtkey
JWT_EXPIRES_IN=3600

# Which deployment file to use from contracts/deployments
# Options: local | ganache | gcp
CONTRACT_NETWORK=local


